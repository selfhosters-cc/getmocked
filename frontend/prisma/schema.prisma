generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  name         String?
  passwordHash String?      @map("password_hash")
  authProvider String       @default("email") @map("auth_provider")
  isAdmin      Boolean      @default(false) @map("is_admin")
  createdAt    DateTime     @default(now()) @map("created_at")
  mockupSets    MockupSet[]
  designs       Design[]
  renderBatches RenderBatch[]
  templateImages TemplateImage[]
  etsyConnections EtsyConnection[]
  toolUsages      ToolUsage[]

  @@map("users")
}

model MockupSet {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  name        String
  description String?
  createdAt     DateTime         @default(now()) @map("created_at")
  colorVariants Json?            @default("[]") @map("color_variants")
  user          User             @relation(fields: [userId], references: [id])
  templates     MockupTemplate[]
  renderBatches RenderBatch[]

  @@map("mockup_sets")
}

model TemplateImage {
  id                   String           @id @default(uuid())
  userId               String?          @map("user_id")
  name                 String
  imagePath            String           @map("image_path")
  thumbnailPath        String?          @map("thumbnail_path")
  defaultOverlayConfig Json?            @map("default_overlay_config")
  defaultMaskPath      String?          @map("default_mask_path")
  rating               Int              @default(0)
  archivedAt           DateTime?        @map("archived_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  user                 User?            @relation(fields: [userId], references: [id])
  templates            MockupTemplate[]
  tags                 TemplateImageTag[]

  @@map("template_images")
}

model Tag {
  id         String             @id @default(uuid())
  name       String             @unique
  archivedAt DateTime?          @map("archived_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  images     TemplateImageTag[]

  @@map("tags")
}

model TemplateImageTag {
  templateImageId String        @map("template_image_id")
  tagId           String        @map("tag_id")
  templateImage   TemplateImage @relation(fields: [templateImageId], references: [id], onDelete: Cascade)
  tag             Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([templateImageId, tagId])
  @@map("template_image_tags")
}

model MockupTemplate {
  id              String          @id @default(uuid())
  mockupSetId     String          @map("mockup_set_id")
  templateImageId String?         @map("template_image_id")
  name            String
  overlayConfig   Json?           @map("overlay_config")
  sortOrder       Int             @default(0) @map("sort_order")
  isFavorite      Boolean         @default(false) @map("is_favorite")
  archivedAt      DateTime?       @map("archived_at")
  mockupSet       MockupSet       @relation(fields: [mockupSetId], references: [id], onDelete: Cascade)
  templateImage   TemplateImage?  @relation(fields: [templateImageId], references: [id])
  renderedMockups RenderedMockup[]

  @@map("mockup_templates")
}

model Design {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  name            String
  imagePath       String          @map("image_path")
  createdAt       DateTime        @default(now()) @map("created_at")
  user            User            @relation(fields: [userId], references: [id])
  renderedMockups RenderedMockup[]
  renderBatches   RenderBatch[]

  @@map("designs")
}

model RenderBatch {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  mockupSetId  String          @map("mockup_set_id")
  designId     String          @map("design_id")
  description  String?
  createdAt    DateTime        @default(now()) @map("created_at")
  user         User            @relation(fields: [userId], references: [id])
  mockupSet    MockupSet       @relation(fields: [mockupSetId], references: [id])
  design       Design          @relation(fields: [designId], references: [id])
  renders      RenderedMockup[]

  @@map("render_batches")
}

model RenderedMockup {
  id                String         @id @default(uuid())
  mockupTemplateId  String         @map("mockup_template_id")
  designId          String         @map("design_id")
  batchId           String?        @map("batch_id")
  renderedImagePath String         @map("rendered_image_path")
  status            String         @default("pending")
  renderOptions     Json?          @map("render_options")
  isFavorite        Boolean        @default(false) @map("is_favorite")
  createdAt         DateTime       @default(now()) @map("created_at")
  mockupTemplate    MockupTemplate @relation(fields: [mockupTemplateId], references: [id], onDelete: Cascade)
  design            Design         @relation(fields: [designId], references: [id])
  batch             RenderBatch?   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  etsyUploads       EtsyUpload[]

  @@map("rendered_mockups")
}

model EtsyConnection {
  id              String         @id @default(uuid())
  userId          String         @map("user_id")
  shopId          String         @map("shop_id")
  shopName        String         @map("shop_name")
  etsyUserId      String         @map("etsy_user_id")
  accessToken     String         @map("access_token")
  refreshToken    String         @map("refresh_token")
  tokenExpiresAt  DateTime       @map("token_expires_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  user            User           @relation(fields: [userId], references: [id])
  uploads         EtsyUpload[]

  @@map("etsy_connections")
}

model EtsyUpload {
  id                String          @id @default(uuid())
  etsyConnectionId  String          @map("etsy_connection_id")
  renderedMockupId  String          @map("rendered_mockup_id")
  etsyListingId     String          @map("etsy_listing_id")
  etsyImageId       String?         @map("etsy_image_id")
  status            String          @default("pending")
  errorMessage      String?         @map("error_message")
  createdAt         DateTime        @default(now()) @map("created_at")
  etsyConnection    EtsyConnection  @relation(fields: [etsyConnectionId], references: [id], onDelete: Cascade)
  renderedMockup    RenderedMockup  @relation(fields: [renderedMockupId], references: [id])

  @@map("etsy_uploads")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model ToolUsage {
  id        String   @id @default(uuid())
  tool      String
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tool_usage")
}
